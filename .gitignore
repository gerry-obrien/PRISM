# =============================================================
# Paris Property Advisor — .gitignore
# =============================================================

# ----- Generated data (reproducible via ml/generate_data.py) -----
data/*.csv

# ----- ML artifacts (reproducible via ml/train.py) -----
ml/artifacts/
ml/plots/
mlruns/
ml/mlflow-artifacts/

# ----- Python -----
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/
*.egg

# ----- Node / Frontend -----
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Environment variables -----
.env
.env.local
